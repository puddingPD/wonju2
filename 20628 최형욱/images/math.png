,\"10\",{\"rel\":\"alternate\",\"hrefLang\":\"x-default\",\"href\":\"https://www.dongascience.com/ko/news/14669\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:title\",\"content\":\"세계적인 명문대 학생이 직접 출제한 수학 문제, 함께 풀어요!\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:description\",\"content\":\"한국판 폴리매스 프로젝트 \"}],[\"$\",\"meta\",\"13\",{\"property\":\"og:site_name\",\"content\":\"동아사이언스\"}],[\"$\",\"meta\",\"14\",{\"property\":\"og:locale\",\"content\":\"ko_KR\"}],[\"$\",\"meta\",\"15\",{\"property\":\"og:image\",\"content\":\"https://image.dongascience.com/Photo/2016/11/14787580704609.jpg\"}],[\"$\",\"meta\",\"16\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"17\",{\"property\":\"article:published_time\",\"content\":\"2016-11-10 15:00:00\"}],[\"$\",\"meta\",\"18\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"19\",{\"name\":\"twitter:title\",\"content\":\"세계적인 명문대 학생이 직접 출제한 수학 문제, 함께 풀어요!\"}],[\"$\",\"meta\",\"20\",{\"name\":\"twitter:description\",\"content\":\"한국판 폴리매스 프로젝트 \"}],[\"$\",\"meta\",\"21\",{\"name\":\"twitter:image\",\"content\":\"https://image.dongascience.com/Photo/2016/11/14787580704609.jpg\"}],[\"$\",\"link\",\"22\",{\"rel\":\"shortcut icon\",\"href\":\"https://img.dongascience.com/ds-symbol.svg\"}],[\"$\",\"link\",\"23\",{\"rel\":\"icon\",\"href\":\"https://img.dongascience.com/ds-symbol.svg\",\"type\":\"image/svg+xml\"}],[\"$\",\"link\",\"24\",{\"rel\":\"apple-touch-icon\",\"href\":\"https://img.dongascience.com/ds-symbol.svg\",\"sizes\":\"180x180\",\"type\":\"image/svg+xml\"}],[\"$\",\"meta\",\"25\",{\"name\":\"next-size-adjust\"}]]\n"])</script><script>self.__next_f.push([1,"8:null\n21:Tb00,"])</script><script>self.__next_f.push([1,"\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cdiv class=\"pic_c\"\u003e\u003cimg width=\"670\" height=\"470\" alt=\"iStockphoto 제공\" src=\"http://image.dongascience.com/Photo/2014/05/13998724989524[1].jpg\" border=\"0\" /\u003e\n\t\u003cdiv class=\"pic_desc\"\u003e\n\t\t\u003cdiv class=\"pic_desc_txt\"\u003eiStockphoto 제공\n\t\t\u003c/div\u003e\n\t\u003c/div\u003e\n\u003c/div\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e폴리매스 프로젝트라고 아시나요?\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e혼자 힘으로 풀기 어려운 수학 문제를\u0026nbsp; 전세계 수학자들이 온라인상에서 아이디어를 주고 받으며 해결하는 것입니다. 2009년 필즈상 수상자인 팀 가워스 주도로 시작된 이 프로젝트는 크게 성공을 거둬 지금도 많은 수학자가 온라인상에서 함께 문제를 풀고 있습니다.\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e올해 3월부터는 미국 메사추세츠공대에서 수학 분야 최우수 고등학생과 대학생으로 대상으로 함께 수학 문제를 푸는 크라우드 매스 프로젝트를 진행하고 있습니다. 크라우스 매스 홈페이지에서 함께 풀 문제를 확인하고, 문제 풀 아이디어가 떠오르면 누구라도 게시판을 글을 쓰면 됩니다. 문제는 영어로 수학 문제를 풀어야 하기 때문에 우리나라 학생들이 참여하기에는 어려운 점이 있습니다.\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e그래서 수학동아에서는 우리나라 청소년을 대상으로 한국판 폴리매스 프로젝트를 준비했습니다. 대한수학회와 국가수리과학연구소와 함께 2017년 1월부터 매달 함께 풀 문제를 제공할 예정입니다.\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003e● 플로매스 맛보기 문제\u003c/strong\u003e \u003c/p\u003e\n\u003cp\u003e프로젝트 시작에 앞서 맛보기 문제를 준비했습니다. 이번 문제는 국가수리과학연구소 소속의 이석형 연구원이 출제했습니다. 이석형 연구원은 미국 프린스턴대에서 수학 박사 과정을 밟고 있으며, 2014년 필즈상 수상자인 만줄 바르가바가 박사 과정 지도 교수입니다.\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e숫자를 맞히는 '업 다운' 게임은 한 사람이 1부터 n 사이에 숫자 하나를 정한다. 그러면 다른 사람이 '이 숫자 이상입니까?'라고 질문은 m번 해서 답을 맞힌다. 보통 이 경우에는 n이 2^m 이하면 질문하는 사람이 항상 답을 맞힐 수 있다. \u003c/p\u003e\n\u003cp\u003e여기서 변형을 해서 대답하는 사람이 m번의 질문 중 거짓말을 한 번 할 수 있다고 하자. 그러면 질문하는 사람이 숫자를 항상 맞힐 수 있는 n의 최댓값은 얼마일까?\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e문제에 관련해서 기발한 아이디어나 답이 떠오른 분은 수학동아 블로그에 덧글을 달아주세요.\u003c/p\u003e\n\u003cp\u003e\u003ca href=\"http://mathdonga.blog.me/220855755340\" target=\"_blank\"\u003ehttp://mathdonga.blog.me/220855755340\u003c/a\u003e\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n\u003cp\u003e\u0026nbsp;\u003c/p\u003e\n"])</script><script>self.__next_f.push([1,"25:{\"ko\":\"폴리매스 프로젝트에서는 어떤 식으로 수학 문제를 함께 풀까요?\",\"en\":\"How do people actually work together to solve math problems in the Polymath project?\"}\n26:{\"ko\":\"세계적인 명문대 학생이 낸 수학 문제는 얼마나 어려울까요?\",\"en\":\"How difficult are math problems created by students from top universities?\"}\n24:[\"$25\",\"$26\"]\n30:{\"title\":\"이 기사가 괜찮으셨나요?\",\"subtitle\":\"메일로 더 많은 기사를 받아보세요!\",\"placeholder\":\"이메일 주소 입력\",\"submitButton\":\"뉴스레터신청\",\"privacyConsent\":\"(필수)개인정보 수집 및 이용에 동의합니다.\",\"marketingConsent\":\"(필수)광고성 정보 수신에 동의합니다.\",\"successMessage\":\"뉴스레터 구독이 완료되었습니다.\",\"errorMessage\":\"구독 중 오류가 발생했습니다. 다시 시도해주세요.\",\"emailRequired\":\"이메일을 입력해주세요.\",\"invalidEmail\":\"올바른 이메일 형식이 아닙니다.\",\"consentRequired\":\"필수 동의 항목을 체크해주세요.\",\"alreadySubscribed\":\"이미 구독 중인 이메일입니다.\"}\n"])</script><script>self.__next_f.push([1,"9:[[\"$\",\"$L1d\",null,{\"articleId\":\"14669\",\"kind\":\"NEWS\"}],[\"$\",\"div\",null,{\"className\":\"print-hide\",\"children\":[\"$\",\"$L1e\",null,{\"locale\":\"ko\",\"articleId\":\"14669\",\"summaries\":[\"수학동아가 대한수학회·국가수리과학연구소와 한국판 온라인 공공 수학 프로젝트를 시작했습니다.\",\"이 프로젝트는 2017년 1월부터 매달 청소년 대상 도전 수학 문제를 무료로 제공하기로 했습니다.\",\"프린스턴대 박사과정 이석형 연구원이 업다운 게임 변형 문제를 맛보기 문제로 제시했습니다.\"]}]}],[\"$\",\"section\",\"article-14669-ko\",{\"className\":\"mx-auto max-w-[1240px] article-detail-section\",\"children\":[false,[\"$\",\"header\",null,{\"className\":\"article-header self-stretch md:border-b border-zinc-100 inline-flex flex-col justify-start items-start md:mb-[60px] w-full\",\"children\":[\"$\",\"div\",null,{\"className\":\"article-title-block self-stretch pb-10 flex flex-col justify-start items-start gap-2 overflow-hidden\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"article-title self-stretch text-neutral-800 text-[28px] md:text-4xl font-bold leading-[1.3] md:leading-[52px] tracking-[-0.84px]\",\"children\":\"세계적인 명문대 학생이 직접 출제한 수학 문제, 함께 풀어요!\"}],[\"$\",\"div\",null,{\"className\":\"article-meta self-stretch inline-flex justify-start items-center gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"article-author text-neutral-800 text-base font-normal